<h1>{{.Name}}</h1>
{{if .Branding}}
<div style="float:right;">
  <img src="https://github.com/marketplace/actions/{{.Name | urlquery}}/icon" height="50"/>
</div>
{{end}}
<p><em>{{.Description}}</em></p>
{{if .Author}}
<p><b>Author:</b> {{.Author}}</p>
{{end}}
{{if .MyCustomField}}
<p><b>Custom Field:</b> {{.MyCustomField}}</p>
{{end}}
<h2>Usage</h2>
<pre>
- uses: {{.Org}}/{{.Repo}}@{{.Version}}
  with:
{{- range $key, $val := .Inputs}}
    {{$key}}: # {{$val.Description}}{{if $val.Default}} (default: {{$val.Default}}){{end}}
{{- end}}
</pre>
<h2>Inputs</h2>
<ul>
{{range $key, $input := .Inputs}}
  <li><b>{{$key}}</b>: {{$input.Description}}{{if $input.Required}} <b>(required)</b>{{end}}{{if $input.Default}} (default: {{$input.Default}}){{end}}</li>
{{end}}
</ul>
{{if .Outputs}}
{{- $outputsLen := len .Outputs -}}
{{- if gt $outputsLen 0 }}
<h2>Outputs</h2>
<ul>
{{range $key, $output := .Outputs}}
  <li><b>{{$key}}</b>: {{$output.Description}}</li>
{{end}}
</ul>
{{end}}
{{end}}
<h2>Example</h2>
<p>See the <a href="./action.yml">action.yml</a> for a full reference.</p>
<h2>Badges</h2>
<p>
  <img src="https://github.com/{{.Org}}/{{.Repo}}/workflows/CI/badge.svg" alt="CI"/>
  <img src="https://img.shields.io/badge/GitHub%20Actions-Marketplace-blue" alt="Marketplace"/>
</p>
<hr/>
