<h1>{{.Name}}</h1>
{{if .Branding}}
<div style="float:right;">
  <img src="https://github.com/marketplace/actions/{{.Name | urlquery}}/icon" height="50"/>
</div>
{{end}}
<p><em>{{.Description}}</em></p>
{{if .LongDescription}}
{{.LongDescription}}
{{end}}
{{/* Author and custom fields removed for compatibility */}}
<h2>Usage</h2>
<pre>
- uses: {{.Org}}/{{.Repo}}@{{.Version}}
  with:
{{- range $key, $val := .Inputs}}
    {{$key}}: # {{$val.Description}}{{if $val.Default}} (default: {{$val.Default}}){{end}}
{{- end}}
</pre>
<h2>Inputs</h2>
<table>
  <thead>
    <tr><th>Key</th><th>Description</th><th>Required</th><th>Default</th></tr>
  </thead>
  <tbody>
{{range $key, $input := .Inputs}}
    <tr>
      <td>{{$key}}</td>
      <td>{{$input.Description}}</td>
      <td>{{if $input.Required}}✔{{else}}✘{{end}}</td>
      <td>{{if $input.Default}}{{$input.Default}}{{else}}-{{end}}</td>
    </tr>
{{end}}
  </tbody>
</table>
{{if .Outputs}}
{{- $outputsLen := len .Outputs -}}
{{- if gt $outputsLen 0 }}
<h2>Outputs</h2>
<table>
  <thead>
    <tr><th>Key</th><th>Description</th></tr>
  </thead>
  <tbody>
{{range $key, $output := .Outputs}}
    <tr>
      <td>{{$key}}</td>
      <td>{{$output.Description}}</td>
    </tr>
{{end}}
  </tbody>
</table>
{{end}}
{{end}}
<h2>Example</h2>
<p>See the <a href="./action.yml">action.yml</a> for a full reference.</p>
<h2>Badges</h2>
<p>
  <img src="https://github.com/{{.Org}}/{{.Repo}}/workflows/CI/badge.svg" alt="CI"/>
  <img src="https://img.shields.io/badge/GitHub%20Actions-Marketplace-blue" alt="Marketplace"/>
</p>
<hr/>
